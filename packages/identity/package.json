{
  "name": "@ahamie/identity",
  "version": "0.1.1",
  "description": "Better-Auth wrapper + ACL + tenant middleware. Organization plugin from day 1 (T19).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./acl": {
      "types": "./dist/acl.d.ts",
      "import": "./dist/acl.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@ahamie/schema": "workspace:*",
    "@ahamie/storage": "workspace:*",
    "@ahamie/telemetry": "workspace:*",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.45.2"
  },
  "peerDependencies": {
    "hono": "^4.12.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "hono": "^4.12.16",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "ahamie": {
    "kind": "runtime",
    "specVersion": "0.1.0"
  }
}
