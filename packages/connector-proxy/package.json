{
  "name": "@ahamie/connector-proxy",
  "version": "0.1.1",
  "description": "Standalone Hono server: token holding, allowlist, MCP-inside, HMAC ingress, audit. Five non-negotiable invariants (I1-I5).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ahamie-proxy": "./dist/bin/ahamie-proxy.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@ahamie/schema": "workspace:*",
    "@ahamie/storage": "workspace:*",
    "@ahamie/telemetry": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.16"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "ahamie": {
    "kind": "runtime",
    "specVersion": "0.1.0"
  }
}
