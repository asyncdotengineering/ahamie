{
  "name": "@ahamie/storage",
  "version": "0.1.0",
  "description": "Drizzle schema, migrations, and pgvector helpers for Ahamie. Postgres everywhere — no PGlite, no SQLite.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./migrate": {
      "types": "./dist/migrate.d.ts",
      "import": "./dist/migrate.js"
    },
    "./test-helpers": {
      "types": "./dist/test-helpers.d.ts",
      "import": "./dist/test-helpers.js"
    }
  },
  "files": [
    "dist",
    "drizzle",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "drizzle:generate": "drizzle-kit generate",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@ahamie/schema": "workspace:*",
    "@ahamie/telemetry": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@testcontainers/postgresql": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "testcontainers": "^11.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "ahamie": {
    "kind": "substrate",
    "specVersion": "0.1.0"
  }
}
