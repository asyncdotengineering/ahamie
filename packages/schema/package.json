{
  "name": "@ahamie/schema",
  "version": "0.1.1",
  "description": "Standard-Schema-conformant Zod re-export with branded ID types and common refinements.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./brand": {
      "types": "./dist/brand.d.ts",
      "import": "./dist/brand.js"
    },
    "./refine": {
      "types": "./dist/refine.d.ts",
      "import": "./dist/refine.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.0.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "ahamie": {
    "kind": "substrate",
    "specVersion": "0.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/octalpixel/ahamie.git",
    "directory": "packages/schema"
  }
}
