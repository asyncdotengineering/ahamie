{
  "name": "ahamie",
  "version": "0.0.0",
  "private": true,
  "description": "Ahamie — the company brain you own. Headless, source-available, self-host-first AI framework.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:core": "turbo run test --filter='!@ahamie/connector-proxy' --filter='!@ahamie/ui'",
    "test:proxy": "turbo run test --filter=@ahamie/connector-proxy",
    "test:ui": "turbo run test --filter=@ahamie/ui",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@changesets/cli": "^2.27.0",
    "@types/node": "^22.10.0",
    "lint-staged": "^15.2.0",
    "simple-git-hooks": "^2.11.0",
    "tsup": "^8.5.1",
    "turbo": "^2.4.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
